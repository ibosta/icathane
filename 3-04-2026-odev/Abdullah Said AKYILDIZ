import turtle
deneme = turtle.Screen()
deneme.bgcolor("white")
deneme.setup(600,400)

kalem = turtle.Turtle()
kalem.speed(8)

kalem.penup()
kalem.goto(0,-100)
kalem.pendown

kalem.color("red")
kalem.begin_fill()
kalem.circle(120)
kalem.end_fill()

kalem.penup()
kalem.goto(-30,-80)
kalem.pendown

kalem.color("white")
kalem.begin_fill()
kalem.circle(100)
kalem.end_fill()

kalem.goto(-90,-190)
kalem.color("red")
kalem.write("KIZILAY",font=("Articulate",40,"bold"))





