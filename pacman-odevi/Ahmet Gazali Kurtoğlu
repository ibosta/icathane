import turtle

scr = turtle.Screen()
t = turtle.Turtle()

scr.title("Pacman")
scr.setup(width=600, height=400)
scr.bgcolor("black")

t.speed(10)
t.up()
t.goto(0, -100)
t.color("yellow")
t.begin_fill()
t.circle(120)
t.end_fill()

t.up()
t.goto(0, 20)
t.color(black)
t.down()

t.begin_fill()
t.right(40)
t.forward(150)
t.left(110)
t.forward(200)

t.end_fill()


turtle.done()
